{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entity Extraction Output",
  "type": "object",
  "properties": {
    "PodReference": {
      "type": [
        "string",
        "array"
      ],
      "items": {
        "type": "string"
      }
    },
    "NodeReference": {
      "type": [
        "string",
        "array"
      ],
      "items": {
        "type": "string"
      }
    },
    "ApplicationID": {
      "type": [
        "string",
        "array"
      ],
      "items": {
        "type": "string"
      }
    },
    "kubernetes_deployment_name": {
      "type": [
        "string",
        "array"
      ],
      "items": {
        "type": "string"
      }
    },
    "backend_service_name": {
      "type": [
        "string",
        "array"
      ],
      "items": {
        "type": "string"
      }
    },
    "kubernetes_namespace_name": {
      "type": [
        "string",
        "array"
      ],
      "items": {
        "type": "string"
      }
    },
    "urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ip": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "rule_id",
          "source_path"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "rule_id": {
            "type": "string"
          },
          "source_path": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "normalization": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}